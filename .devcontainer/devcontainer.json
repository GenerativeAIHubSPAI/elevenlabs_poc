{
  "name": "Voice Assistant",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",

  "portsAttributes": {
    "3000": { "label": "Frontend", "onAutoForward": "notify" },
    "8000": { "label": "Backend", "onAutoForward": "notify" }
  },
  "otherPortsAttributes": { "onAutoForward": "ignore" },

  // Extensiones que se instalan automáticamente dentro del contenedor
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "dsznajder.es7-react-js-snippets"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[python]": {
          "editor.defaultFormatter": "ms-python.python"
        }
      }
    }
  },

  // Arranca ambos servidores automáticamente al abrir el contenedor
  "postCreateCommand": "pip install -r /workspace/requirements.txt && cd /workspace/frontend && npm install"
}
